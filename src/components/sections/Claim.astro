---
import Container from '../ui/Container.astro';
import Claim from '../ui/Claim.astro';
import type { Translations } from '@/i18n/schema.ts';

type Props = {
  t: Translations['claim'];
};

const { t } = Astro.props;
---

<section
  id="claim"
  class="flex min-h-dvh flex-col justify-center bg-subtle px-6 py-10"
  data-reveal="fade-scale"
>
  <Container className="text-white text-center max-w-4xl">
    <Claim text={t.text} />
  </Container>
</section>
