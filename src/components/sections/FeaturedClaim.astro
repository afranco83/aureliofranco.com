---
import Container from '../../components/ui/Container.astro';
import Claim from '../../components/ui/Claim.astro';
import type { Translations } from '@/i18n/schema.ts';

type Props = {
  t: Translations['featuredClaim'];
};

const { t } = Astro.props;
---

<section
  id="featured-claim"
  class="flex min-h-dvh flex-col justify-center bg-accent p-8 text-center text-accent-soft px-6 py-10"
  data-reveal="fade-scale"
>
  <Container>
    <Claim text={t.text} />
  </Container>
</section>
