---
import Container from '../ui/Container.astro';
import { Image } from 'astro:assets';
import aurelioFrancoImg from '../../assets/images/hero/aureliofranco.webp';
import type { Translations } from '@/i18n/schema.ts';

type Props = {
  t: Translations['hero'];
};

const { t } = Astro.props;
---

<section
  id="hero"
  class="relative flex items-center justify-center overflow-hidden bg-black min-h-dvh px-9 py-20 lg:p-9"
  data-reveal="doors"
>
  <Container
    className="h-full p-0 flex flex-col justify-center items-center gap-12 max-w-7xl lg:flex-row"
  >
    <div class="h-auto text-center w-full lg:text-left">
      <h1 class="text-white text-3xl font-extrabold min-[440px]:text-5xl lg:text-6xl xl:text-7xl">
        {t.title}
      </h1>
      <p class="text-accent text-xl font-extralight min-[440px]:text-3xl lg:text-4xl">
        {t.subtitle}
      </p>
    </div>
    <Image
      src={aurelioFrancoImg}
      alt="Aurelio Franco"
      width={958}
      height={958}
      loading="eager"
      fetchpriority="high"
      class="w-60 sm:w-72 md:w-80 lg:w-auto lg:max-w-xl h-auto aspect-square"
    />
  </Container>
  <div class="bg-accent" data-reveal-door="left" aria-hidden="true"></div>
  <div class="bg-accent" data-reveal-door="right" aria-hidden="true"></div>
</section>
