---
import { twMerge } from 'tailwind-merge';

type Props = {
  id: string;
  name: string;
  label: string;
  type?: 'text' | 'email';
  required?: boolean;
  minlength?: number;
  maxlength?: number;
  autocomplete?: string;
  placeholder?: string;
  className?: string;
};

const {
  id,
  name,
  label,
  type = 'text',
  required = true,
  minlength,
  maxlength,
  autocomplete,
  placeholder,
  className,
} = Astro.props;

const inputClassName = twMerge(
  'w-full rounded-lg border border-muted px-4 py-3 text-sm text-foreground placeholder:text-subtle focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent',
  className,
);
---

<div class="flex flex-col gap-2 text-left">
  <label for={id} class="text-xs font-medium tracking-widest text-subtle uppercase">{label}</label>
  <input
    id={id}
    name={name}
    type={type}
    required={required}
    minlength={minlength}
    maxlength={maxlength}
    autocomplete={autocomplete}
    placeholder={placeholder}
    class={inputClassName}
  />
</div>
