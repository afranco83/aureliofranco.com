---
import Icon from './Icon.astro';
import { twMerge } from 'tailwind-merge';

type Props = {
  id: string;
  titleId: string;
  closeLabel: string;
  className?: string;
};

const { id, titleId, closeLabel, className } = Astro.props;
---

<dialog
  id={id}
  aria-labelledby={titleId}
  class={twMerge(
    'm-auto w-full max-w-md rounded-2xl p-8 text-left open:flex open:flex-col open:gap-6 backdrop:bg-black/50',
    className,
  )}
>
  <div class="relative flex flex-col gap-6">
    <button
      type="button"
      data-modal-close
      aria-label={closeLabel}
      class="absolute top-0 right-0 text-subtle transition-colors hover:text-accent focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent"
    >
      <Icon name="CloseRound" size="sm" />
    </button>
    <slot />
  </div>
</dialog>
