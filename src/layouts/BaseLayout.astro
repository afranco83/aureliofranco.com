---
import '../styles/global.css';
import type { Locale } from '@/i18n/index.ts';
import Navbar from '@/components/Navbar.astro';

type Props = {
  title?: string;
  description?: string;
  lang?: Locale;
};

const { title = 'Aurelio Franco', description = 'Frontend Developer', lang = 'es' } =
  Astro.props;

const siteUrl = Astro.site?.href ?? 'https://www.aureliofranco.com/';
const canonicalUrl = lang === 'en' ? `${siteUrl}en/` : siteUrl;
const ogLocale = lang === 'en' ? 'en_US' : 'es_ES';

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Aurelio Franco',
  url: siteUrl,
  email: 'info@aureliofranco.com',
  telephone: '+34661468441',
  jobTitle: 'Frontend Developer & Product Leader',
  description,
  knowsAbout:
    lang === 'en'
      ? [
          'Frontend Development',
          'React',
          'Next.js',
          'TypeScript',
          'JavaScript',
          'Artificial Intelligence',
          'Product Management',
          'UX Design',
          'SEO',
          'CI/CD',
        ]
      : [
          'Desarrollo Frontend',
          'React',
          'Next.js',
          'TypeScript',
          'JavaScript',
          'Inteligencia Artificial',
          'Gestión de Producto',
          'UX Design',
          'SEO',
          'CI/CD',
        ],
  sameAs: ['https://www.linkedin.com/in/aureliofranco', 'https://github.com/afranco83'],
});
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      document.documentElement.classList.add('js-reveal');
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Aurelio Franco" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#c28a2e" />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="es" href={siteUrl} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}en/`} />
    <link rel="alternate" hreflang="x-default" href={siteUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="Aurelio Franco" />

    <meta property="og:image" content={`${siteUrl}og-image-${lang}.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}og-image-${lang}.png`} />

    <script is:inline type="application/ld+json" set:html={jsonLd} />
  </head>

  <body>
    <Navbar lang={lang} />
    <main class="flex flex-col">
      <slot />
    </main>
    <footer class="mt-16 md:mt-24 lg:mt-40">
      <slot name="footer" />
    </footer>
    <script>
      import '@/scripts/reveal.ts';
      import '@/scripts/curtains.ts';
    </script>
  </body>
</html>
