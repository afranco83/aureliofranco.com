---
import '../styles/global.css';
import type { Locale } from '@/i18n/index.ts';
import Navbar from '@/components/Navbar.astro';

type Props = {
  title?: string;
  description?: string;
  lang?: Locale;
};

const { title = 'Aurelio Franco', description = 'Frontend Developer', lang = 'es' } =
  Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>

  <body>
    <Navbar lang={lang} />
    <main class="flex flex-col gap-40">
      <slot />
    </main>
  </body>
</html>
