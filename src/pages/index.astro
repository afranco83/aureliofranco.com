---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getTranslations } from '@/i18n/index.ts';

import Hero from '@/components/sections/Hero.astro';
import About from '@/components/sections/About.astro';
import FeaturedClaim from '@/components/sections/FeaturedClaim.astro';
import Stack from '@/components/sections/Stack.astro';
import Howto from '@/components/sections/Howto.astro';
import Claim from '@/components/sections/Claim.astro';
import Social from '@/components/sections/Social.astro';

const t = getTranslations('es');
---

<BaseLayout title={t.meta.title} description={t.meta.description} lang="es" nav={t.nav}>
  <Hero t={t.hero} />
  <About t={t.aboutMe} />
  <FeaturedClaim t={t.featuredClaim} />
  <Howto t={t.howTo} />
  <Stack t={t.stack} />
  <Claim t={t.claim} />
  <Social slot="footer" t={t.social} />
</BaseLayout>
