---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getTranslations } from '@/i18n/index.ts';

const t = getTranslations('es');
---

<BaseLayout title="Design Playground" nav={t.nav}>
  <main class="container py-16 space-y-16">
    <section class="space-y-6">
      <h1 class="text-6xl font-bold">
        Aurelio <span class="text-accent">Franco</span>
      </h1>

      <p class="max-w-2xl text-lg text-subtle">
        Frontend Developer creating accessible and performant digital
        experiences.
      </p>
    </section>

    <section class="space-y-4">
      <h2 class="text-3xl font-semibold">Colors</h2>

      <div class="flex flex-wrap gap-4">
        <div class="size-20 rounded-lg bg-foreground"></div>
        <div class="size-20 rounded-lg bg-subtle"></div>
        <div class="size-20 rounded-lg bg-gray"></div>
        <div class="size-20 rounded-lg bg-muted"></div>
        <div class="size-20 rounded-lg bg-accent"></div>
        <div class="size-20 rounded-lg bg-accent-soft"></div>
        <div class="size-20 rounded-lg bg-accent-dark"></div>
      </div>
    </section>

    <section class="space-y-4">
      <h2 class="text-3xl font-semibold">Typography</h2>

      <div class="space-y-2">
        <h1 class="text-6xl font-bold">Heading 1</h1>
        <h2 class="text-5xl font-bold">Heading 2</h2>
        <h3 class="text-4xl font-semibold">Heading 3</h3>

        <p>Default paragraph text using Be Vietnam Pro.</p>

        <p class="text-muted">Muted paragraph text.</p>

        <a href="#" class="text-accent underline underline-offset-4">
          Accent link
        </a>
      </div>
    </section>

    <section class="space-y-4">
      <h2 class="text-3xl font-semibold">Buttons</h2>

      <div class="flex gap-4">
        <button class="rounded-md bg-accent px-5 py-3 font-medium text-white">
          Primary
        </button>

        <button class="rounded-md border border-border px-5 py-3 font-medium">
          Secondary
        </button>
      </div>
    </section>

    <section class="space-y-4">
      <h2 class="text-3xl font-semibold">Card</h2>

      <article class="max-w-md rounded-lg border border-border p-6">
        <span class="text-sm text-accent"> Featured </span>

        <h3 class="mt-2 text-xl font-semibold">Portfolio Project</h3>

        <p class="mt-3 text-subtle">
          Example card to validate spacing, borders and typography.
        </p>
      </article>
    </section>
  </main>
</BaseLayout>
